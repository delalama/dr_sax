---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { formatDate } from "@/lib/format";
import { getStaticPostBySlug, getStaticPosts } from "@/lib/staticPosts";

export async function getStaticPaths() {
  const posts = await getStaticPosts();
  return posts.map((post) => ({ params: { slug: post.slug } }));
}

const { slug } = Astro.params;
if (!slug) {
  return Astro.redirect("/");
}

const post = await getStaticPostBySlug(slug);
if (!post) {
  return Astro.redirect("/");
}

const base = import.meta.env.BASE_URL;
const pageTitle = `${post.title} | Dr. Sax`;
type DescriptionBlock = {
  type: "heading" | "paragraph";
  text: string;
};

const toDescriptionBlocks = (rawText: string): DescriptionBlock[] =>
  rawText
  .split(/\r?\n\r?\n/)
  .map((block) => block.trim())
  .filter(Boolean)
  .map((block) => {
    const oneLine = block.replace(/\r?\n+/g, " ").trim();
    const markdownHeading = oneLine.match(/^#{1,6}\s+(.+)$/);
    if (markdownHeading?.[1]) {
      return { type: "heading", text: markdownHeading[1].trim() };
    }

    if (/^cap(?:i|\u00ED)tulo\b/i.test(oneLine)) {
      return { type: "heading", text: oneLine };
    }

    return { type: "paragraph", text: oneLine };
  });

const descriptionBlocks: DescriptionBlock[] = toDescriptionBlocks(post.description);
const descriptionBlocksByLang: Partial<Record<"en" | "ca", DescriptionBlock[]>> = {};
if (post.descriptionTranslations.en) {
  descriptionBlocksByLang.en = toDescriptionBlocks(post.descriptionTranslations.en);
}
if (post.descriptionTranslations.ca) {
  descriptionBlocksByLang.ca = toDescriptionBlocks(post.descriptionTranslations.ca);
}

const getBlockTranslation = (lang: "en" | "ca", index: number, type: DescriptionBlock["type"]) => {
  const translatedBlocks = descriptionBlocksByLang[lang];
  if (!translatedBlocks || translatedBlocks.length <= index) {
    return undefined;
  }
  const translated = translatedBlocks[index];
  if (translated.type !== type) {
    return undefined;
  }
  return translated.text;
};

const normalizeText = (value: string) =>
  value
    .normalize("NFKD")
    .toLowerCase()
    .replace(/[^\w\s]/g, " ")
    .replace(/\s+/g, " ")
    .trim();

const firstParagraph = descriptionBlocks.find((block) => block.type === "paragraph")?.text ?? "";
const normalizedExcerpt = normalizeText(post.excerpt);
const normalizedDescription = normalizeText(post.description);
const showSummary =
  Boolean(normalizedExcerpt) &&
  (!normalizedDescription || !normalizedDescription.includes(normalizedExcerpt)) &&
  (!firstParagraph || normalizedExcerpt !== normalizeText(firstParagraph));

type GalleryRenderItem =
  | { type: "heading"; level: 1 | 2; text: string }
  | { type: "image"; image: (typeof post.images)[number]; index: number };

const galleryRenderItems: GalleryRenderItem[] = [];
let imageCounter = 0;
for (const item of post.gallery) {
  if (item.type === "heading") {
    galleryRenderItems.push(item);
    continue;
  }

  imageCounter += 1;
  galleryRenderItems.push({ type: "image", image: item.image, index: imageCounter });
}
---

<BaseLayout title={pageTitle} description={post.excerpt}>
  <article class="container project">
    <a href={base} class="back" data-i18n="backToWorks">Volver a trabajos</a>
    <header>
      <p class="pill">{post.workType}</p>
      <h1>{post.title}</h1>
      {showSummary && (
        <p
          class="summary"
          data-i18n-dynamic={post.excerpt}
          data-i18n-dynamic-en={post.excerptTranslations.en}
          data-i18n-dynamic-ca={post.excerptTranslations.ca}
        >
          {post.excerpt}
        </p>
      )}
      <div class="meta">
        {post.model && (
          <span>
            <strong data-i18n="modelLabel">Modelo:</strong> {post.model}
          </span>
        )}
        <span>
          <strong data-i18n="publishedLabel">Publicado:</strong>{" "}
          <span data-i18n-date={post.publishedAt}>{formatDate(post.publishedAt)}</span>
        </span>
        <span>
          <strong data-i18n="folderLabel">Carpeta:</strong> {post.folderName}
        </span>
      </div>
      {post.tags.length > 0 && (
        <div class="post-tags">
          {post.tags.map((tag) => (
            <a class="tag-link" href={`${base}?tag=${encodeURIComponent(tag)}`}>
              {tag}
            </a>
          ))}
        </div>
      )}
    </header>

    {descriptionBlocks.length > 0 && (
      <section class="desc">
        {descriptionBlocks.map((block, index) =>
          block.type === "heading" ? (
            <h2
              class="desc-title"
              data-i18n-dynamic={block.text}
              data-i18n-dynamic-en={getBlockTranslation("en", index, "heading")}
              data-i18n-dynamic-ca={getBlockTranslation("ca", index, "heading")}
            >
              {block.text}
            </h2>
          ) : (
            <p
              data-i18n-dynamic={block.text}
              data-i18n-dynamic-en={getBlockTranslation("en", index, "paragraph")}
              data-i18n-dynamic-ca={getBlockTranslation("ca", index, "paragraph")}
            >
              {block.text}
            </p>
          )
        )}
      </section>
    )}

    <section class="gallery">
      {galleryRenderItems.map((item) =>
        item.type === "heading" ? (
          item.level === 1 ? (
            <h2 class="gallery-heading level-1" data-i18n-dynamic={item.text}>
              {item.text}
            </h2>
          ) : (
            <h3 class="gallery-heading level-2" data-i18n-dynamic={item.text}>
              {item.text}
            </h3>
          )
        ) : (
          <figure>
            <div class="img-title">{item.image.fileName}</div>
            <button
              class="media-open"
              type="button"
              data-full-src={item.image.url}
              data-full-type={item.image.kind}
              data-full-alt={item.image.caption}
              aria-label={`Ver ${item.image.kind === "video" ? "video" : "imagen"} ${item.index} en pantalla completa`}
            >
              <div class="media-frame">
                {item.image.kind === "video" ? (
                  <video class="media-el" src={item.image.url} preload="metadata" muted playsinline />
                ) : (
                  <img class="media-el" src={item.image.url} alt={item.image.caption} loading="lazy" />
                )}
              </div>
              {item.image.kind === "video" && (
                <span class="video-indicator" aria-hidden="true">
                  <span class="video-indicator-icon"></span>
                  <span class="video-indicator-label">Play</span>
                </span>
              )}
            </button>
            <figcaption>
              <span class="cap-index">{String(item.index).padStart(2, "0")}</span>
              <span data-i18n-dynamic={item.image.caption}>{item.image.caption}</span>
            </figcaption>
          </figure>
        )
      )}
    </section>
  </article>

  <dialog id="lightbox-image-dialog" class="lightbox">
    <button
      id="lightbox-image-close"
      class="lightbox-close"
      type="button"
      aria-label="Cerrar imagen"
      data-i18n="close"
    >
      Cerrar
    </button>
    <img id="lightbox-image" src="" alt="" />
  </dialog>

  <dialog id="lightbox-video-dialog" class="lightbox">
    <button
      id="lightbox-video-close"
      class="lightbox-close"
      type="button"
      aria-label="Cerrar video"
      data-i18n="close"
    >
      Cerrar
    </button>
    <video id="lightbox-video-player" controls playsinline preload="metadata" webkit-playsinline></video>
    <p id="lightbox-video-error" class="lightbox-video-error" hidden>
      No se puede mostrar la imagen del video en este navegador. Prueba otro codec (H.264).
    </p>
  </dialog>
</BaseLayout>

<script>
  const imageDialog = document.querySelector("#lightbox-image-dialog");
  const videoDialog = document.querySelector("#lightbox-video-dialog");
  const dialogImage = document.querySelector("#lightbox-image");
  const dialogVideo = document.querySelector("#lightbox-video-player");
  const dialogVideoError = document.querySelector("#lightbox-video-error");
  const imageCloseButton = document.querySelector("#lightbox-image-close");
  const videoCloseButton = document.querySelector("#lightbox-video-close");
  const openButtons = document.querySelectorAll(".media-open");
  const MIN_ZOOM = 1;
  const MAX_ZOOM = 8;
  const ZOOM_STEP = 0.14;
  let zoom = 1;
  let panX = 0;
  let panY = 0;
  let isDragging = false;
  let movedDuringDrag = false;
  let dragStartX = 0;
  let dragStartY = 0;
  let dragStartPanX = 0;
  let dragStartPanY = 0;

  const clamp = (value, min, max) => Math.min(max, Math.max(min, value));

  const getPanLimits = () => {
    if (!dialogImage) return { maxX: 0, maxY: 0 };
    const maxX = Math.max(0, (dialogImage.clientWidth * (zoom - 1)) / 2);
    const maxY = Math.max(0, (dialogImage.clientHeight * (zoom - 1)) / 2);
    return { maxX, maxY };
  };

  const clampPan = () => {
    const { maxX, maxY } = getPanLimits();
    panX = clamp(panX, -maxX, maxX);
    panY = clamp(panY, -maxY, maxY);
  };

  const refreshTransform = () => {
    if (!dialogImage) return;
    dialogImage.style.transform = `translate(${panX}px, ${panY}px) scale(${zoom})`;
  };

  const refreshCursor = () => {
    if (!dialogImage) return;
    dialogImage.style.transition = isDragging ? "none" : "transform 0.04s linear";
    if (zoom <= 1) {
      dialogImage.style.cursor = "zoom-in";
      return;
    }
    dialogImage.style.cursor = isDragging ? "grabbing" : "grab";
  };

  const applyZoom = (nextZoom, originX, originY) => {
    if (!dialogImage) return;

    zoom = clamp(nextZoom, MIN_ZOOM, MAX_ZOOM);
    if (zoom === 1) {
      panX = 0;
      panY = 0;
    } else if (typeof originX === "number" && typeof originY === "number") {
      dialogImage.style.transformOrigin = `${originX}px ${originY}px`;
    }
    clampPan();
    refreshTransform();
    refreshCursor();
  };

  const showImageInDialog = (src, alt) => {
    if (!imageDialog || !dialogImage) return;
    dialogImage.setAttribute("src", src);
    dialogImage.setAttribute("alt", alt);
    applyZoom(1);
    if (typeof imageDialog.showModal === "function") {
      imageDialog.showModal();
    } else {
      imageDialog.setAttribute("open", "open");
    }
  };

  const showVideoInDialog = (src) => {
    if (!videoDialog || !dialogVideo || !dialogVideoError) return;
    dialogVideoError.hidden = true;
    dialogVideo.setAttribute("src", src);
    dialogVideo.currentTime = 0;
    dialogVideo.load();
    if (typeof videoDialog.showModal === "function") {
      videoDialog.showModal();
    } else {
      videoDialog.setAttribute("open", "open");
    }
    const playAttempt = dialogVideo.play();
    if (playAttempt && typeof playAttempt.catch === "function") {
      playAttempt.catch(() => {});
    }
  };

  const closeDialogSafely = (dialogEl) => {
    if (!dialogEl) return;
    if (typeof dialogEl.close === "function") {
      dialogEl.close();
      return;
    }
    dialogEl.removeAttribute("open");
  };

  if (
    imageDialog &&
    videoDialog &&
    dialogImage &&
    dialogVideo &&
    dialogVideoError &&
    imageCloseButton &&
    videoCloseButton &&
    openButtons.length > 0
  ) {
    openButtons.forEach((button) => {
      button.addEventListener("click", () => {
        const src = button.getAttribute("data-full-src");
        const mediaType = button.getAttribute("data-full-type") ?? "image";
        const alt = button.getAttribute("data-full-alt") ?? "Imagen ampliada";
        if (!src) return;

        if (mediaType === "video") {
          showVideoInDialog(src);
        } else {
          showImageInDialog(src, alt);
        }
      });
    });

    imageCloseButton.addEventListener("click", () => closeDialogSafely(imageDialog));
    videoCloseButton.addEventListener("click", () => closeDialogSafely(videoDialog));
    dialogImage.addEventListener(
      "wheel",
      (event) => {
        event.preventDefault();
        const rect = dialogImage.getBoundingClientRect();
        const originX = event.clientX - rect.left;
        const originY = event.clientY - rect.top;
        const factor = event.deltaY < 0 ? 1 + ZOOM_STEP : 1 - ZOOM_STEP;
        applyZoom(zoom * factor, originX, originY);
      },
      { passive: false }
    );

    dialogImage.addEventListener("click", () => {
      if (movedDuringDrag) {
        movedDuringDrag = false;
        return;
      }
      applyZoom(zoom > 1 ? 1 : 2.2);
    });

    dialogImage.addEventListener("pointerdown", (event) => {
      if (zoom <= 1) return;
      isDragging = true;
      movedDuringDrag = false;
      dragStartX = event.clientX;
      dragStartY = event.clientY;
      dragStartPanX = panX;
      dragStartPanY = panY;
      dialogImage.setPointerCapture(event.pointerId);
      refreshCursor();
    });

    dialogImage.addEventListener("pointermove", (event) => {
      if (!isDragging || zoom <= 1) return;
      const dx = event.clientX - dragStartX;
      const dy = event.clientY - dragStartY;
      if (Math.abs(dx) > 2 || Math.abs(dy) > 2) {
        movedDuringDrag = true;
      }
      panX = dragStartPanX + dx;
      panY = dragStartPanY + dy;
      clampPan();
      refreshTransform();
    });

    const endDrag = () => {
      if (!isDragging) return;
      isDragging = false;
      refreshCursor();
    };

    dialogImage.addEventListener("pointerup", endDrag);
    dialogImage.addEventListener("pointercancel", endDrag);

    dialogVideo.addEventListener("click", () => {
      if (dialogVideo.paused) {
        const playAttempt = dialogVideo.play();
        if (playAttempt && typeof playAttempt.catch === "function") {
          playAttempt.catch(() => {});
        }
        return;
      }
      dialogVideo.pause();
    });

    dialogVideo.addEventListener("error", () => {
      dialogVideoError.hidden = false;
    });

    dialogVideo.addEventListener("loadedmetadata", () => {
      const hasVisualTrack = dialogVideo.videoWidth > 0 && dialogVideo.videoHeight > 0;
      dialogVideoError.hidden = hasVisualTrack;
    });

    imageDialog.addEventListener("close", () => {
      applyZoom(1);
      movedDuringDrag = false;
      isDragging = false;
      refreshCursor();
      dialogImage.removeAttribute("src");
      dialogImage.setAttribute("alt", "");
    });

    videoDialog.addEventListener("close", () => {
      dialogVideo.pause();
      dialogVideo.removeAttribute("src");
      dialogVideo.load();
      dialogVideoError.hidden = true;
    });

    imageDialog.addEventListener("click", (event) => {
      if (event.target === imageDialog) {
        closeDialogSafely(imageDialog);
      }
    });

    videoDialog.addEventListener("click", (event) => {
      if (event.target === videoDialog) {
        closeDialogSafely(videoDialog);
      }
    });
  }
</script>

<style>
  .project {
    padding: 2rem 0 4rem;
  }

  .back {
    color: var(--accent-dark);
    font-weight: 700;
  }

  header h1 {
    font-size: clamp(2.4rem, 5vw, 4.2rem);
    margin-top: 0.7rem;
  }

  .summary {
    max-width: 70ch;
    color: var(--ink-soft);
    font-size: 1.08rem;
  }

  .meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem 1.2rem;
    margin: 1rem 0 1.5rem;
    color: var(--ink-soft);
    font-size: 0.95rem;
  }

  .desc {
    max-width: 75ch;
    color: var(--ink-soft);
  }

  .desc-title {
    margin: 1.2rem 0 0.45rem;
    color: var(--ink);
    font-size: 1.05rem;
    letter-spacing: 0.02em;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin-bottom: 1rem;
  }

  .tag-link {
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 0.22rem 0.65rem;
    font-size: 0.82rem;
    color: var(--ink-soft);
    background: color-mix(in srgb, var(--card), white 12%);
  }

  .gallery {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 0.8rem;
    margin-top: 1.2rem;
  }

  .gallery-heading {
    grid-column: 1 / -1;
    margin: 1.4rem 0 0.25rem;
    color: var(--ink);
    letter-spacing: 0.01em;
    line-height: 1.2;
  }

  .gallery-heading.level-1 {
    font-size: clamp(1.35rem, 2.3vw, 1.9rem);
    font-weight: 800;
    margin-top: 1.8rem;
  }

  .gallery-heading.level-2 {
    font-size: clamp(1.02rem, 1.6vw, 1.25rem);
    font-weight: 700;
    color: var(--ink-soft);
    margin-top: 0.95rem;
  }

  figure {
    grid-column: span 6;
    margin: 0;
    border: 1px solid var(--line);
    border-radius: 12px;
    overflow: hidden;
    background: var(--card);
  }

  .img-title {
    font-family: monospace;
    font-size: 0.82rem;
    line-height: 1.35;
    padding: 0.55rem 0.75rem;
    border-bottom: 1px solid var(--line);
    background: color-mix(in srgb, var(--card), white 20%);
    color: var(--ink-soft);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .media-open {
    display: block;
    position: relative;
    width: 100%;
    border: 0;
    padding: 0;
    background: transparent;
  }

  .media-frame {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 11;
    overflow: hidden;
    background: #0d0d0d;
  }

  .media-el {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  .media-frame video.media-el {
    pointer-events: none;
  }

  .media-open[data-full-type="image"] {
    cursor: zoom-in;
  }

  .media-open[data-full-type="video"] {
    cursor: pointer;
  }

  .video-indicator {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.65rem;
    background: radial-gradient(circle, rgba(0, 0, 0, 0.34), rgba(0, 0, 0, 0.18) 45%, transparent 70%);
    color: #fff;
    font-size: 0.92rem;
    line-height: 1;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    font-weight: 700;
    pointer-events: none;
  }

  .video-indicator-icon {
    display: block;
    width: 88px;
    height: 88px;
    border-radius: 999px;
    border: 2px solid rgba(255, 255, 255, 0.92);
    background: rgba(0, 0, 0, 0.52);
    position: relative;
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.45);
  }

  .video-indicator-icon::after {
    content: "";
    position: absolute;
    left: 36px;
    top: 27px;
    width: 0;
    height: 0;
    border-top: 16px solid transparent;
    border-bottom: 16px solid transparent;
    border-left: 25px solid #fff;
  }

  .video-indicator-label {
    text-shadow: 0 2px 9px rgba(0, 0, 0, 0.7);
  }

  figcaption {
    display: flex;
    gap: 0.6rem;
    align-items: baseline;
    padding: 0.65rem 0.8rem;
    color: var(--ink-soft);
    font-size: 0.9rem;
    border-top: 1px solid var(--line);
    background: color-mix(in srgb, var(--card), white 15%);
  }

  .cap-index {
    font-weight: 700;
    color: var(--accent-dark);
    min-width: 1.8rem;
  }

  .lightbox {
    border: 0;
    padding: 0;
    background: transparent;
    max-width: min(96vw, 1400px);
  }

  .lightbox[open] {
    position: fixed;
    inset: 0;
    margin: auto;
    width: fit-content;
    height: fit-content;
    z-index: 9999;
  }

  .lightbox::backdrop {
    background: rgba(0, 0, 0, 0.85);
  }

  .lightbox img,
  .lightbox video {
    display: block;
    max-width: 96vw;
    max-height: 90vh;
    object-fit: contain;
    border-radius: 8px;
    transform-origin: center center;
    transition: transform 0.04s linear;
    user-select: none;
    touch-action: none;
  }

  .lightbox img {
    cursor: zoom-in;
  }

  .lightbox video {
    width: min(96vw, 1400px);
    height: auto;
    background: #000;
    border-radius: 8px;
  }

  .lightbox-video-error {
    color: #fff3d8;
    background: rgba(0, 0, 0, 0.6);
    border: 1px solid rgba(255, 255, 255, 0.45);
    border-radius: 10px;
    padding: 0.55rem 0.75rem;
    font-size: 0.88rem;
    margin: 0.65rem auto 0;
    max-width: min(92vw, 780px);
    text-align: center;
  }

  .lightbox-close {
    position: fixed;
    top: 1rem;
    right: 1rem;
    border: 1px solid #fff;
    background: rgba(0, 0, 0, 0.55);
    color: #fff;
    border-radius: 999px;
    padding: 0.4rem 0.9rem;
    cursor: pointer;
  }

  @media (max-width: 760px) {
    figure {
      grid-column: span 12;
    }
  }
</style>

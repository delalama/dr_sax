---
import { SITE } from "@/lib/site";

interface Props {
  title?: string;
  description?: string;
}

const { title = SITE.title, description = SITE.description } = Astro.props as Props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Archivo:wght@400;500;700&family=Cormorant+Garamond:wght@500;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --bg: #f4efe8;
    --ink: #111111;
    --ink-soft: #3e3a35;
    --accent: #9a4d22;
    --accent-dark: #5f2f16;
    --card: #fffdf8;
    --line: #d7c4af;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    min-height: 100vh;
    font-family: "Archivo", sans-serif;
    color: var(--ink);
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--bg), white 26%) 0%, color-mix(in srgb, var(--bg), white 8%) 58%, var(--bg) 100%),
      radial-gradient(circle at 10% 0%, #f8e9d0 0, transparent 30%),
      radial-gradient(circle at 95% 10%, #f2d6bf 0, transparent 35%),
      url("/general/escritorio.jpg"),
      var(--bg);
    background-repeat: no-repeat, no-repeat, no-repeat, no-repeat, repeat;
    background-size: auto, auto, auto, clamp(460px, 56vw, 760px) auto, auto;
    background-position: top, 10% 0%, 95% 10%, center 1.5rem, center;
    line-height: 1.55;
  }

  h1,
  h2,
  h3 {
    font-family: "Cormorant Garamond", serif;
    letter-spacing: 0.01em;
    line-height: 1.1;
    margin: 0;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  .container {
    width: min(1100px, 92%);
    margin: 0 auto;
  }

  .pill {
    display: inline-block;
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 0.25rem 0.75rem;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-soft);
    background: color-mix(in srgb, var(--card), white 20%);
  }

  @media (max-width: 640px) {
    h1 {
      font-size: 2.25rem;
    }
  }
</style>
